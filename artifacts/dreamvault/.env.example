# DreamVault (frontend) - Supabase configuration
# For local development: Copy this file to .env.local and fill in your values
# For Vercel production: See .env.production.example and set in Vercel dashboard
#
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional fallback supported by src/lib/supabase.ts
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
