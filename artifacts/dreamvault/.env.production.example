# DreamVault Production Environment (Vercel)
# These variables MUST be set in Vercel dashboard for production builds
# https://vercel.com/docs/environment-variables
#
# Steps to configure:
# 1. Go to your Vercel project dashboard
# 2. Project Settings > Environment Variables
# 3. Add these variables for Production environment (IMPORTANT: select "Production" not just "Dev")
# 4. Trigger a redeploy after adding variables (git push or manual redeploy from Vercel)
#
# Get values from your Supabase project:
# https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api
#
# Paste your Supabase URL (looks like: https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Paste your Supabase Anon Key (starts with eyJ...)
VITE_SUPABASE_ANON_KEY=
